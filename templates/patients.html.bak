




<h2>Patients List</h2>
<button onclick="window.print()">Print</button>

<script>

function printTable(){

var content = document.getElementById("printArea").innerHTML;

var win = window.open("","","width=900,height=700");

win.document.write(content);

win.document.close();

win.print();

}

</script>
<table border="1">

<tr>
<th>ID</th>
<th>Name</th>
<th>Age</th>
<th>Gender</th>
<th>Mobile</th>
<th>Action</th>
</tr>

{% for p in patients %}

<tr>
<td>{{p[0]}}</td>
<td>{{p[1]}}</td>
<td>{{p[2]}}</td>
<td>{{p[3]}}</td>
<td>{{p[4]}}</td>

<td>
<a href="/edit/{{p[0]}}">Edit</a>
<a href="/delete/{{p[0]}}">Delete</a>
</td>

</tr>

{% endfor %}

</table>